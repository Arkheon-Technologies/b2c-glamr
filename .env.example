# ─── Application ───────────────────────────────────────────
APP_ENV=development

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/glamr_dev?schema=public

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=7
AUTH_RESET_TOKEN_TTL_MINUTES=30

# ─── API ───────────────────────────────────────────────────
API_PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Stripe (test keys) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (SendGrid) ─────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=bookings@glamr.com

# ─── Storage (S3-compatible) ──────────────────────────────
# Provider-agnostic keys (preferred)
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=

# AWS-compatible fallback keys
AWS_S3_BUCKET=glamr-dev-assets
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
PORTFOLIO_UPLOAD_URL_TTL_SECONDS=900

# ─── Frontend (public) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
