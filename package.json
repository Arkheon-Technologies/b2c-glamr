{
  "name": "glamr",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "npm run test --workspaces --if-present",
    "type-check:api": "tsc -p apps/api/tsconfig.json --noEmit",
    "clean": "turbo clean",
    "dev:web": "turbo dev --filter=@glamr/web",
    "dev:api": "turbo dev --filter=@glamr/api",
    "dev:all": "turbo dev --filter=@glamr/web --filter=@glamr/api",
    "db:generate": "npm run generate --workspace=@glamr/db",
    "db:push": "npm run push --workspace=@glamr/db",
    "db:migrate": "npm run migrate --workspace=@glamr/db",
    "db:studio": "npm run studio --workspace=@glamr/db",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:staging:api": "./scripts/deploy-api.sh staging",
    "deploy:staging:web": "./scripts/deploy-web.sh staging",
    "deploy:production": "./scripts/deploy.sh production",
    "deploy:production:api": "./scripts/deploy-api.sh production",
    "deploy:production:web": "./scripts/deploy-web.sh production"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.0"
}
