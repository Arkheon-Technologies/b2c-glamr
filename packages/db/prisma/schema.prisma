generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users & Auth ──────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  emailVerified   Boolean   @default(false) @map("email_verified")
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  fullName        String    @map("full_name") @db.VarChar(100)
  phone           String?   @db.VarChar(20)
  phoneVerified   Boolean   @default(false) @map("phone_verified")
  avatarUrl       String?   @map("avatar_url")
  authProvider    String    @default("email") @map("auth_provider") @db.VarChar(20)
  oauthId         String?   @map("oauth_id") @db.VarChar(255)
  locale          String    @default("en") @db.Char(2)
  timezone        String?   @db.VarChar(50)
  isPlatformAdmin Boolean   @default(false) @map("is_platform_admin")
  notificationPreferences Json @default("{}") @map("notification_preferences")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  customerProfile     CustomerProfile?
  ownedBusinesses     Business[]        @relation("BusinessOwner")
  staffMemberships    StaffMember[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  appointments        Appointment[]     @relation("CustomerAppointments")
  reviews             Review[]
  customerBusinessStats CustomerBusinessStat[]
  waitlistEntries     WaitlistEntry[]
  walkInQueueEntries  WalkInQueue[]     @relation("WalkInCustomer")
  portfolioConsents   PortfolioItem[]   @relation("PortfolioCustomer")
  patchTestRecords    PatchTestRecord[] @relation("PatchTestCustomer")
  intakeFormResponses IntakeFormResponse[]
  consentDocuments    ConsentDocument[]
  packageCredits          PackageCredit[]
  referralsMade           Referral[]              @relation("Referrer")
  referralsReceived       Referral[]              @relation("Referred")
  payments                Payment[]
  invoices                Invoice[]
  walletLedger            WalletLedger[]
  loyaltyLedger           LoyaltyLedger[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?

  @@map("users")
}

model CustomerProfile {
  userId              String   @id @map("user_id") @db.Uuid
  favoriteBusinesses  String[] @default([]) @map("favorite_businesses") @db.Uuid
  favoriteTechnicians String[] @default([]) @map("favorite_technicians") @db.Uuid
  totalBookings       Int      @default(0) @map("total_bookings")
  referralCode        String?  @unique @map("referral_code") @db.VarChar(20)
  hairType            String?  @map("hair_type") @db.VarChar(50)
  skinType            String?  @map("skin_type") @db.VarChar(50)
  prefs               Json?
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model CustomerBusinessStat {
  customerId    String   @map("customer_id") @db.Uuid
  businessId    String   @map("business_id") @db.Uuid
  bookingCount  Int      @default(0) @map("booking_count")
  totalSpentCents Int    @default(0) @map("total_spent_cents")
  loyaltyTier   String   @default("none") @map("loyalty_tier") @db.VarChar(20)
  isVip         Boolean  @default(false) @map("is_vip")
  noShowCount   Int      @default(0) @map("no_show_count")
  firstBookingAt DateTime? @map("first_booking_at") @db.Timestamptz()
  lastBookingAt DateTime? @map("last_booking_at") @db.Timestamptz()
  internalNotes String?  @map("internal_notes")
  tags          String[] @default([])

  user     User     @relation(fields: [customerId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@id([customerId, businessId])
  @@map("customer_business_stats")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceInfo Json?     @map("device_info")
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ─── Business ──────────────────────────────────────────────────────

model Business {
  id                    String   @id @default(uuid()) @db.Uuid
  ownerId               String   @map("owner_id") @db.Uuid
  name                  String   @db.VarChar(100)
  slug                  String   @unique @db.VarChar(120)
  businessType          String   @default("studio") @map("business_type") @db.VarChar(20)
  description           String?
  verticals             String[] @default([])
  planTier              String   @default("solo_artist") @map("plan_tier") @db.VarChar(20)
  stripeAccountId       String?  @map("stripe_account_id") @db.VarChar(50)
  stripeSubscriptionId  String?  @map("stripe_subscription_id") @db.VarChar(50)
  isVerified            Boolean  @default(false) @map("is_verified")
  verificationStatus    String   @default("unverified") @map("verification_status") @db.VarChar(20)
  settings              Json     @default("{}")
  instagramHandle       String?  @map("instagram_handle") @db.VarChar(50)
  logoUrl               String?  @map("logo_url")
  coverImageUrl         String?  @map("cover_image_url")
  totalBookings         Int      @default(0) @map("total_bookings")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  owner               User                    @relation("BusinessOwner", fields: [ownerId], references: [id])
  locations            BusinessLocation[]
  staffMembers         StaffMember[]
  services             Service[]
  resources            Resource[]
  cancellationPolicies CancellationPolicy[]
  appointments         Appointment[]
  reviews              Review[]
  closures             BusinessClosure[]
  customerStats        CustomerBusinessStat[]
  walkInQueue          WalkInQueue[]
  portfolioItems       PortfolioItem[]
  patchTestRecords     PatchTestRecord[]
  intakeFormTemplates  IntakeFormTemplate[]
  intakeFormResponses  IntakeFormResponse[]
  consentDocuments     ConsentDocument[]
  packages             Package[]
  packageCredits       PackageCredit[]
  discountRules        DiscountRule[]
  loyaltyTiers         LoyaltyTier[]
  payments             Payment[]
  invoices             Invoice[]
  featuredListings          FeaturedListing[]
  referrals                 Referral[]
  rebookingSuggestions      RebookingSuggestion[]
  serviceAreas              ServiceArea[]
  qaThreads                 QaThread[]
  stripeConnectAccount      StripeConnectAccount?
  campaigns                 Campaign[]
  messageTemplates          MessageTemplate[]
  webhooks                  Webhook[]
  integrationConnections    IntegrationConnection[]
  reviewSentimentSnapshot   ReviewSentimentSnapshot?
  whiteLabelTheme           Json?    @map("white_label_theme")

  @@map("businesses")
}

model BusinessLocation {
  id           String   @id @default(uuid()) @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  name         String?  @db.VarChar(100)
  addressLine1 String   @map("address_line1") @db.VarChar(200)
  addressLine2 String?  @map("address_line2") @db.VarChar(200)
  city         String   @db.VarChar(100)
  neighborhood String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  countryCode  String   @map("country_code") @db.Char(2)
  latitude     Decimal  @db.Decimal(10, 8)
  longitude    Decimal  @db.Decimal(11, 8)
  timezone     String   @db.VarChar(50)
  phone        String?  @db.VarChar(20)
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffMembers StaffMember[]
  services     Service[]
  resources    Resource[]
  appointments Appointment[]
  walkInQueue  WalkInQueue[]

  @@map("business_locations")
}

model BeautyVertical {
  id           String @id @default(uuid()) @db.Uuid
  slug         String @unique @db.VarChar(50)
  name         String @db.VarChar(100)
  icon         String? @db.VarChar(50)
  displayOrder Int    @default(0) @map("display_order")
  schemaConfig Json   @default("{}") @map("schema_config")

  services Service[]

  @@map("beauty_verticals")
}

// ─── Staff ─────────────────────────────────────────────────────────

model StaffMember {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  businessId            String   @map("business_id") @db.Uuid
  locationId            String?  @map("location_id") @db.Uuid
  role                  String   @default("technician") @db.VarChar(20)
  displayName           String   @map("display_name") @db.VarChar(100)
  isMedicalProfessional Boolean  @default(false) @map("is_medical_professional")
  isActive              Boolean  @default(true) @map("is_active")
  commissionPct         Float?   @map("commission_pct")
  commissionFlatCents   Int?     @map("commission_flat_cents")
  isBoothRenter         Boolean  @default(false) @map("is_booth_renter")
  boothRentCents        Int?     @map("booth_rent_cents")
  revenueKeepPct        Float?   @map("revenue_keep_pct")
  level                 String   @default("standard") @db.VarChar(20) // junior | standard | senior
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user              User               @relation(fields: [userId], references: [id])
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location          BusinessLocation?  @relation(fields: [locationId], references: [id])
  technicianProfile TechnicianProfile?
  serviceStaff      ServiceStaff[]
  schedules         Schedule[]
  scheduleExceptions ScheduleException[]
  appointments      Appointment[]
  appointmentPhases AppointmentPhase[]
  reviews           Review[]
  portfolioItems    PortfolioItem[]
  waitlistEntries   WaitlistEntry[]
  rebookingSuggestions RebookingSuggestion[]

  @@map("staff_members")
}

model TechnicianProfile {
  staffId         String   @id @map("staff_id") @db.Uuid
  bio             String?
  specializations String[] @default([])
  languages       String[] @default([])
  instagramHandle String?  @map("instagram_handle") @db.VarChar(50)
  slug            String   @unique @db.VarChar(120)
  portfolioCount  Int      @default(0) @map("portfolio_count")
  avgRating       Decimal  @default(0) @map("avg_rating") @db.Decimal(3, 2)
  bookingCount    Int      @default(0) @map("booking_count")
  avatarUrl       String?  @map("avatar_url")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("technician_profiles")
}

// ─── Services ──────────────────────────────────────────────────────

model Service {
  id                        String   @id @default(uuid()) @db.Uuid
  businessId                String   @map("business_id") @db.Uuid
  locationId                String?  @map("location_id") @db.Uuid
  verticalId                String?  @map("vertical_id") @db.Uuid
  name                      String   @db.VarChar(100)
  description               String?
  durationActiveMin         Int      @map("duration_active_min")
  durationProcessingMin     Int      @default(0) @map("duration_processing_min")
  durationFinishMin         Int      @default(0) @map("duration_finish_min")
  priceType                 String   @map("price_type") @db.VarChar(20)
  priceCents                Int?     @map("price_cents")
  priceMaxCents             Int?     @map("price_max_cents")
  currency                  String   @default("EUR") @db.Char(3)
  priceDisplayMode          String   @default("always_visible") @map("price_display_mode") @db.VarChar(20)
  patchTestRequired         Boolean  @default(false) @map("patch_test_required")
  patchTestValidityHours    Int      @default(72) @map("patch_test_validity_hours")
  consultationRequired      Boolean  @default(false) @map("consultation_required")
  followUpIntervalDays      Int?     @map("follow_up_interval_days")
  rebookingIntervalDays     Int?     @map("rebooking_interval_days")
  minIntervalDays           Int?     @map("min_interval_days")
  intakeFormTemplateId      String?  @map("intake_form_template_id") @db.Uuid
  photoConsentRequired      Boolean  @default(false) @map("photo_consent_required")
  medicalProfessionalRequired Boolean @default(false) @map("medical_professional_required")
  packageEligible           Boolean  @default(false) @map("package_eligible")
  bufferBeforeMin           Int      @default(0) @map("buffer_before_min")
  bufferAfterMin            Int      @default(0) @map("buffer_after_min")
  bookingNoticeHours        Int      @default(0) @map("booking_notice_hours")
  cancellationPolicyId      String?  @map("cancellation_policy_id") @db.Uuid
  variantGroupId            String?  @map("variant_group_id") @db.Uuid
  isActive                  Boolean  @default(true) @map("is_active")
  photoUrls                 String[] @default([]) @map("photo_urls")
  displayOrder              Int      @default(0) @map("display_order")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  business           Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location           BusinessLocation?   @relation(fields: [locationId], references: [id])
  vertical           BeautyVertical?     @relation(fields: [verticalId], references: [id])
  cancellationPolicy CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id])
  serviceStaff       ServiceStaff[]
  serviceAddons      ServiceAddon[]
  requiredResources  ServiceRequiredResource[]
  appointments       Appointment[]
  waitlistEntries    WaitlistEntry[]
  walkInQueueEntries WalkInQueue[]
  packages           Package[]
  patchTestRecords   PatchTestRecord[]
  rebookingSuggestions RebookingSuggestion[]

  @@map("services")
}

model ServiceStaff {
  serviceId String @map("service_id") @db.Uuid
  staffId   String @map("staff_id") @db.Uuid

  service Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@id([serviceId, staffId])
  @@map("service_staff")
}

model ServiceAddon {
  id           String  @id @default(uuid()) @db.Uuid
  serviceId    String  @map("service_id") @db.Uuid
  name         String  @db.VarChar(100)
  description  String?
  priceCents   Int     @map("price_cents")
  durationMin  Int     @default(0) @map("duration_min")
  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0) @map("display_order")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_addons")
}

model ServiceRequiredResource {
  serviceId  String @map("service_id") @db.Uuid
  resourceId String @map("resource_id") @db.Uuid

  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id])

  @@id([serviceId, resourceId])
  @@map("service_required_resources")
}

model Resource {
  id         String  @id @default(uuid()) @db.Uuid
  businessId String  @map("business_id") @db.Uuid
  locationId String? @map("location_id") @db.Uuid
  type       String  @db.VarChar(50) // 'chair','pedicure_chair','treatment_room','wash_basin','laser_machine','couples_room'
  name       String  @db.VarChar(100)
  isActive   Boolean @default(true) @map("is_active")

  business            Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location            BusinessLocation?       @relation(fields: [locationId], references: [id])
  serviceRequirements ServiceRequiredResource[]
  appointmentResources AppointmentResource[]

  @@map("resources")
}

model CancellationPolicy {
  id               String @id @default(uuid()) @db.Uuid
  businessId       String @map("business_id") @db.Uuid
  name             String @db.VarChar(100)
  freeCancelHours  Int    @map("free_cancel_hours")
  lateCancelFeePct Int    @default(100) @map("late_cancel_fee_pct")
  noShowFeePct     Int    @default(100) @map("no_show_fee_pct")
  description      String?

  business Business  @relation(fields: [businessId], references: [id])
  services Service[]

  @@map("cancellation_policies")
}

// ─── Scheduling ────────────────────────────────────────────────────

model Schedule {
  id              String  @id @default(uuid()) @db.Uuid
  schedulableType String  @map("schedulable_type") @db.VarChar(20)
  schedulableId   String  @map("schedulable_id") @db.Uuid
  dayOfWeek       Int     @map("day_of_week") @db.SmallInt
  startTime       String  @map("start_time") @db.VarChar(5) // "09:00"
  endTime         String  @map("end_time") @db.VarChar(5)   // "17:00"
  isBreak         Boolean @default(false) @map("is_break")

  staff StaffMember? @relation(fields: [schedulableId], references: [id])

  @@unique([schedulableType, schedulableId, dayOfWeek, startTime])
  @@map("schedules")
}

model ScheduleException {
  id              String    @id @default(uuid()) @db.Uuid
  schedulableType String    @map("schedulable_type") @db.VarChar(20)
  schedulableId   String    @map("schedulable_id") @db.Uuid
  exceptionDate   DateTime  @map("exception_date") @db.Date
  isAvailable     Boolean   @default(false) @map("is_available")
  startTime       String?   @map("start_time") @db.VarChar(5)
  endTime         String?   @map("end_time") @db.VarChar(5)
  reason          String?   @db.VarChar(200)

  staff StaffMember? @relation(fields: [schedulableId], references: [id])

  @@unique([schedulableType, schedulableId, exceptionDate])
  @@map("schedule_exceptions")
}

model BusinessClosure {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  closureDate DateTime @map("closure_date") @db.Date
  reason      String?  @db.VarChar(200)

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, closureDate])
  @@map("business_closures")
}

// ─── Appointments ──────────────────────────────────────────────────

model Appointment {
  id                String   @id @default(uuid()) @db.Uuid
  businessId        String   @map("business_id") @db.Uuid
  locationId        String?  @map("location_id") @db.Uuid
  serviceId         String   @map("service_id") @db.Uuid
  staffId           String   @map("staff_id") @db.Uuid
  customerId        String?  @map("customer_id") @db.Uuid
  startAt           DateTime @map("start_at") @db.Timestamptz()
  endAt             DateTime @map("end_at") @db.Timestamptz()
  status            String   @default("confirmed") @db.VarChar(30)
  hasProcessingTime Boolean  @default(false) @map("has_processing_time")
  bookingSource     String   @default("marketplace") @map("booking_source") @db.VarChar(20)
  idempotencyKey    String?  @unique @map("idempotency_key") @db.Uuid
  guestEmail        String?  @map("guest_email") @db.VarChar(255)
  guestName         String?  @map("guest_name") @db.VarChar(100)
  guestPhone        String?  @map("guest_phone") @db.VarChar(20)
  notes                String?
  paymentIntentId      String?  @map("payment_intent_id") @db.VarChar(100)
  paymentStatus        String?  @map("payment_status") @db.VarChar(20) // authorized | captured | refunded
  cancellationFeeCents Int?     @map("cancellation_fee_cents")
  noShowFeeAmountCents Int?     @map("no_show_fee_amount_cents")
  preferencesJson      Json?    @map("preferences")
  guestToken           String?  @map("guest_token") @db.VarChar(100)
  reviewToken          String?  @unique @map("review_token") @db.VarChar(100)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  business          Business              @relation(fields: [businessId], references: [id])
  location          BusinessLocation?     @relation(fields: [locationId], references: [id])
  service           Service               @relation(fields: [serviceId], references: [id])
  staff             StaffMember           @relation(fields: [staffId], references: [id])
  customer          User?                 @relation("CustomerAppointments", fields: [customerId], references: [id])
  phases            AppointmentPhase[]
  resources         AppointmentResource[]
  review            Review?
  payments          Payment[]
  invoices          Invoice[]
  portfolioItems      PortfolioItem[]
  appliedDiscounts    AppliedDiscount[]
  patchTestRecords    PatchTestRecord[]
  consentDocuments    ConsentDocument[]
  intakeFormResponses IntakeFormResponse[]
  bookingCounters     BookingCounter[]
  tips                Tip[]
  attachments         BookingAttachment[]
  series              AppointmentSeries?

  @@index([staffId, startAt, status])
  @@index([businessId, startAt])
  @@index([customerId, startAt])
  @@map("appointments")
}

model AppointmentPhase {
  id                 String   @id @default(uuid()) @db.Uuid
  appointmentId      String   @map("appointment_id") @db.Uuid
  staffId            String   @map("staff_id") @db.Uuid
  phase              String   @db.VarChar(20) // 'active','processing','finish'
  startAt            DateTime @map("start_at") @db.Timestamptz()
  endAt              DateTime @map("end_at") @db.Timestamptz()
  technicianRequired Boolean  @map("technician_required")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  staff       StaffMember @relation(fields: [staffId], references: [id])

  @@index([staffId, startAt, endAt])
  @@map("appointment_phases")
}

model AppointmentResource {
  id            String   @id @default(uuid()) @db.Uuid
  appointmentId String   @map("appointment_id") @db.Uuid
  resourceId    String   @map("resource_id") @db.Uuid
  startAt       DateTime @map("start_at") @db.Timestamptz()
  endAt         DateTime @map("end_at") @db.Timestamptz()

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceId], references: [id])

  @@index([resourceId, startAt, endAt])
  @@map("appointment_resources")
}

// ─── Walk-In Queue ─────────────────────────────────────────────────

model WalkInQueue {
  id               String    @id @default(uuid()) @db.Uuid
  businessId       String    @map("business_id") @db.Uuid
  locationId       String    @map("location_id") @db.Uuid
  customerName     String    @map("customer_name") @db.VarChar(100)
  phone            String?   @db.VarChar(20)
  customerId       String?   @map("customer_id") @db.Uuid
  serviceId        String?   @map("service_id") @db.Uuid
  staffPreference  String?   @map("staff_preference") @db.Uuid
  position         Int
  estimatedWaitMin Int?      @map("estimated_wait_min")
  joinedAt         DateTime  @default(now()) @map("joined_at") @db.Timestamptz()
  notifiedAt       DateTime? @map("notified_at") @db.Timestamptz()
  servedAt         DateTime? @map("served_at") @db.Timestamptz()
  status           String    @default("waiting") @db.VarChar(20)

  business Business          @relation(fields: [businessId], references: [id])
  location BusinessLocation  @relation(fields: [locationId], references: [id])
  customer User?             @relation("WalkInCustomer", fields: [customerId], references: [id])
