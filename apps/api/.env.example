# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/glamr_dev?schema=public"

# JWT
JWT_SECRET="glamr-dev-secret-change-in-production"
AUTH_RESET_TOKEN_TTL_MINUTES=30

# Frontend URL (CORS)
FRONTEND_URL="http://localhost:3000"

# Stripe (test keys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SendGrid
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="bookings@glamr.com"

# Storage (S3-compatible)
# Provider-agnostic keys (preferred)
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ENDPOINT=""
STORAGE_PUBLIC_BASE_URL=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_FORCE_PATH_STYLE=""

# AWS-compatible fallback keys
AWS_S3_BUCKET="glamr-dev-assets"
AWS_REGION="eu-west-1"
AWS_S3_PUBLIC_BASE_URL=""
PORTFOLIO_UPLOAD_URL_TTL_SECONDS=900

# Redis
REDIS_URL="redis://localhost:6379"

# App
PORT=4000
NODE_ENV=development
