}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  kind      String    @db.VarChar(60) // booking.confirmed | reminder.24h | review.prompt | ...
  channel   String    @db.VarChar(20) // sms | email | push | inapp
  status    String    @default("queued") @db.VarChar(20) // queued | sent | delivered | failed
  payload   Json?
  sendAt    DateTime? @map("send_at") @db.Timestamptz()
  sentAt    DateTime? @map("sent_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@index([status, sendAt])
  @@map("notifications")
}

model NotificationPreference {
  userId     String   @id @map("user_id") @db.Uuid
  email      Json?
  sms        Json?
  push       Json?
  quietHours Json?    @map("quiet_hours")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

model BookingAttachment {
  id            String   @id @default(uuid()) @db.Uuid
  appointmentId String   @map("appointment_id") @db.Uuid
  url           String
  kind          String   @db.VarChar(20) // inspiration | consent | invoice
  uploadedBy    String?  @map("uploaded_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("booking_attachments")
}

// ─── Phase 3: Calendar / Messaging / Commission ────────────────────

model AppointmentSeries {
  id                    String   @id @default(uuid()) @db.Uuid
  templateAppointmentId String   @unique @map("template_appointment_id") @db.Uuid
  rrule                 String   // iCal RRULE string
  materializedUntil     DateTime @map("materialized_until") @db.Timestamptz()

  appointment Appointment @relation(fields: [templateAppointmentId], references: [id])

  @@map("appointment_series")
}

model MessageThread {
  id            String    @id @default(uuid()) @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  businessId    String    @map("business_id") @db.Uuid
  appointmentId String?   @map("appointment_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz()

  messages Message[]

  @@index([customerId, lastMessageAt(sort: Desc)])
  @@index([businessId, lastMessageAt(sort: Desc)])
  @@map("message_threads")
}

model Message {
  id           String        @id @default(uuid()) @db.Uuid
  threadId     String        @map("thread_id") @db.Uuid
  senderKind   String        @map("sender_kind") @db.VarChar(20) // customer | staff | system
  senderUserId String?       @map("sender_user_id") @db.Uuid
  body         String?
  attachments  Json?
  readAt       DateTime?     @map("read_at") @db.Timestamptz()
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("messages")
}

model CommissionLedger {
  id            String   @id @default(uuid()) @db.Uuid
  staffId       String   @map("staff_id") @db.Uuid
  appointmentId String   @map("appointment_id") @db.Uuid
  amountCents   Int      @map("amount_cents")
  kind          String   @db.VarChar(20) // service | tip | deduction
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([staffId, createdAt(sort: Desc)])
  @@map("commission_ledger")
}

// ─── Phase 4: Feed / Social ────────────────────────────────────────

model FeedPost {
  id              String   @id @default(uuid()) @db.Uuid
  portfolioItemId String   @map("portfolio_item_id") @db.Uuid
  staffId         String   @map("staff_id") @db.Uuid
  businessId      String   @map("business_id") @db.Uuid
  category        String?  @db.VarChar(50)
  heroPhotoUrl    String   @map("hero_photo_url")
  caption         String?
  likeCount       Int      @default(0) @map("like_count")
  saveCount       Int      @default(0) @map("save_count")
  commentCount    Int      @default(0) @map("comment_count")
  publishedAt     DateTime @map("published_at") @db.Timestamptz()

  likes    FeedLike[]
  comments FeedComment[]

  @@index([businessId, publishedAt(sort: Desc)])
  @@index([staffId, publishedAt(sort: Desc)])
  @@map("feed_posts")
}

model FeedLike {
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("feed_likes")
}

model FeedComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("feed_comments")
}

model Follow {
  followerId    String   @map("follower_id") @db.Uuid
  targetStaffId String   @map("target_staff_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@id([followerId, targetStaffId])
  @@map("follows")
}

model Collection {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  isPublic  Boolean  @default(false) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  items CollectionItem[]

  @@index([userId])
  @@map("collections")
}

model CollectionItem {
  collectionId String   @map("collection_id") @db.Uuid
  feedPostId   String   @map("feed_post_id") @db.Uuid
  addedAt      DateTime @default(now()) @map("added_at") @db.Timestamptz()

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([collectionId, feedPostId])
  @@map("collection_items")
}

// ─── Phase 4: Analytics ────────────────────────────────────────────

model ReviewSentimentSnapshot {
  businessId    String   @id @map("business_id") @db.Uuid
  praisedThemes Json     @map("praised_themes")
  flaggedThemes Json     @map("flagged_themes")
  snapshotAt    DateTime @default(now()) @map("snapshot_at") @db.Timestamptz()

  business Business @relation(fields: [businessId], references: [id])

  @@map("review_sentiment_snapshots")
}

// ─── Phase 4: Marketing & Campaigns ───────────────────────────────

model Campaign {
  id          String    @id @default(uuid()) @db.Uuid
  businessId  String    @map("business_id") @db.Uuid
  name        String    @db.VarChar(100)
  segment     Json
  channels    String[]
  templateId  String?   @map("template_id") @db.Uuid
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz()
  sentAt      DateTime? @map("sent_at") @db.Timestamptz()
  status      String    @default("draft") @db.VarChar(20) // draft | scheduled | sending | sent | failed
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId, createdAt(sort: Desc)])
  @@map("campaigns")
}

model MessageTemplate {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  kind       String   @db.VarChar(50) // confirmation | reminder_24h | reschedule | cancel | review_prompt | reengagement
  subject    String?  @db.VarChar(200)
  bodyEmail  String?  @map("body_email")
  bodySms    String?  @map("body_sms")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  business Business @relation(fields: [businessId], references: [id])

  @@map("message_templates")
}

// ─── Phase 4: Webhooks & Integrations ─────────────────────────────

model Webhook {
  id         String            @id @default(uuid()) @db.Uuid
  businessId String            @map("business_id") @db.Uuid
  url        String
  secret     String
  events     String[]
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  business   Business          @relation(fields: [businessId], references: [id])
  deliveries WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id          BigInt    @id @default(autoincrement())
  webhookId   String    @map("webhook_id") @db.Uuid
  event       String    @db.VarChar(100)
  payload     Json
  statusCode  Int?      @map("status_code")
  attempt     Int       @default(1)
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt(sort: Desc)])
  @@map("webhook_deliveries")
}

model IntegrationConnection {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  provider    String   @db.VarChar(50) // google_calendar | google_business | mailchimp | brevo | zapier
  config      Json?
  tokens      Json? // store encrypted refresh/access tokens
  connectedAt DateTime @map("connected_at") @db.Timestamptz()

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, provider])
  @@map("integration_connections")
}
